{
  "_comment": "Add this to your AI agent config to enable MCP servers. Replace the example with your actual server configuration.",
  "mcpServers": {
    "faostat": {
      "command": "python",
      "args": ["-m", "faostat_mcp.server"],
      "cwd": "path/to/faostat-mcp",
      "env": {
        "FAOSTAT_API_TOKEN": "your_token_here",
        "FAOSTAT_BASE_URL": "https://faostatservices.fao.org/api/v1",
        "FAOSTAT_DEFAULT_LANG": "en"
      }
    }
  }
}
