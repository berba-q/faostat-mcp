# FAOSTAT MCP Server — Environment Variables
# Copy this file to .env and fill in your values.
# Get your token and credentials from the FAOSTAT developer portal:
# https://www.fao.org/faostat/en/#developer-portal

# --- Required (at least one of token OR username+password) ---

# API token obtained from the FAOSTAT developer portal
FAOSTAT_API_TOKEN=

# Or authenticate with username and password (used to obtain a token automatically)
FAOSTAT_USERNAME=
FAOSTAT_PASSWORD=

# --- Nice to have  ---

# Base URL for the FAOSTAT API (default: https://faostatservices.fao.org/api/v1)
FAOSTAT_BASE_URL=https://faostatservices.fao.org/api/v1

# Default language for API responses (default: en)
FAOSTAT_DEFAULT_LANG=en
